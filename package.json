{
  "name": "zenmala",
  "version": "1.0.0",
  "description": "Offline mala counter PWA packaged with Capacitor.",
  "private": true,
  "scripts": {
    "start": "python3 -m http.server 4173 --directory www",
    "serve": "python3 -m http.server 4173 --directory www",
    "check:pwa": "node scripts/check-pwa.js",
    "cap:build": "npx cap sync",
    "copy:ios": "npx cap copy ios",
    "sync:ios": "npx cap sync ios",
    "open:ios": "npx cap open ios",
    "copy:android": "npx cap copy android",
    "sync:android": "npx cap sync android",
    "open:android": "npx cap open android",
    "generate:apk": "npm run sync:android && cd android && ./gradlew assembleDebug",
    "generate:aab": "npm run sync:android && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/cli": "8.3.1",
    "@capacitor/core": "8.3.1",
    "@capacitor/ios": "8.3.1"
  }
}
