{
  "name": "zenmala",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web --clear && node scripts/prepare-pwa-export.js",
    "export:github": "EXPO_BASE_URL=/Mala-Chanter-Emergent expo export --platform web --clear && node scripts/prepare-pwa-export.js /Mala-Chanter-Emergent",
    "cap:build": "npm run export:web && npx cap sync",
    "copy:ios": "npm run export:web && npx cap copy ios",
    "sync:ios": "npm run export:web && npx cap sync ios",
    "open:ios": "npx cap open ios",
    "copy:android": "npm run export:web && npx cap copy android",
    "sync:android": "npm run export:web && npx cap sync android",
    "open:android": "npx cap open android",
    "generate:apk": "npm run sync:android && cd android && ./gradlew assembleDebug",
    "generate:aab": "npm run sync:android && cd android && ./gradlew bundleRelease",
    "check:pwa": "node scripts/check-pwa.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/cli": "8.3.1",
    "@capacitor/core": "8.3.1",
    "@capacitor/ios": "8.3.1",
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.0",
    "expo-audio": "~1.0.13",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.3",
    "typescript": "~5.9.2"
  }
}
